        <mxCell id="e3l" value="Consume" style="edgeLabel;html=1;fontSize=9;" vertex="1" connectable="0" parent="e3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- ============================================ -->
        <!-- 3. VALIDATION (pipeline.rs) -->
        <!-- ============================================ -->
        <mxCell id="parse" value="&lt;b&gt;Parse CanonicalEnvelope&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Head (event_id, tenant_id, object_type,&lt;br&gt;change_kind) + Body (JSON snapshot)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="395" width="250" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e_http_parse" edge="1" source="http" target="parse" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_rmq_parse" edge="1" source="rmq_consumer" target="parse" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="validate" value="&lt;b&gt;validate_envelope()&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;ULID format check&lt;br&gt;Required fields: tenant_id, event_name&lt;br&gt;change_kind normalization&lt;br&gt;body not null&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="490" width="230" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_parse_val" edge="1" source="parse" target="validate" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Validation decision diamond -->
        <mxCell id="d_val" value="Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="605" y="600" width="80" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_val_d" edge="1" source="validate" target="d_val" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="val_fail" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;400 Bad Request&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Return validation errors&lt;br&gt;Record intake_failed to MongoDB&lt;br&gt;DiagnosticsActor.RecordError&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="590" width="210" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e_val_no" edge="1" source="d_val" target="val_fail" style="rounded=1;strokeColor=#b85450;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_val_no_l" value="No" style="edgeLabel;html=1;fontSize=9;fontColor=#b85450;fontStyle=1;" vertex="1" connectable="0" parent="e_val_no"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- ============================================ -->
        <!-- 4. ASSIGNER — Playbook Matching -->
        <!-- ============================================ -->
        <mxCell id="assigner_title" value="&lt;b&gt;ASSIGNER&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="590" y="695" width="110" height="20" as="geometry" />
        </mxCell>

        <mxCell id="assigner" value="&lt;b&gt;Playbook Lookup&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;build_tadpole_from_store()&lt;br&gt;OR AssignerActor (file-based)&lt;br&gt;&lt;br&gt;Match: object_type + change_kind (trigger)&lt;br&gt;OR CEL expression (match_expr)&lt;br&gt;Case-insensitive regex match&lt;br&gt;Codex versioning support&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="720" width="250" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e_d_assigner" edge="1" source="d_val" target="assigner" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_d_assigner_l" value="Yes" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontColor=#2e7d32;" vertex="1" connectable="0" parent="e_d_assigner"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Playbook matched? -->
        <mxCell id="d_pb" value="Playbook&lt;br&gt;matched?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="595" y="865" width="100" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e_a_dpb" edge="1" source="assigner" target="d_pb" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="no_pb" value="&lt;font color=&quot;#e65100&quot;&gt;&lt;b&gt;INCONCLUSIVE&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;No playbooks matched&lt;br&gt;Return GovernanceConclusion&lt;br&gt;with INCONCLUSIVE decision&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="860" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e_dpb_no" edge="1" source="d_pb" target="no_pb" style="rounded=1;strokeColor=#d6b656;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_dpb_no_l" value="No" style="edgeLabel;html=1;fontSize=9;fontColor=#e65100;fontStyle=1;" vertex="1" connectable="0" parent="e_dpb_no"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Build Tadpole -->
        <mxCell id="build_tadpole" value="&lt;b&gt;Build Tadpole&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Assign playbook &amp;amp; rules to Tadpole&lt;br&gt;Load active rules from MongoDB&lt;br&gt;Order by (is_critical desc, order_seq asc)&lt;br&gt;Build RuleSpec with conditions&lt;br&gt;Set execution_mode (Fail_First etc.)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="975" width="230" height="85" as="geometry" />
        </mxCell>
        <mxCell id="e_dpb_yes" edge="1" source="d_pb" target="build_tadpole" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_dpb_yes_l" value="Yes" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontColor=#2e7d32;" vertex="1" connectable="0" parent="e_dpb_yes"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- ============================================ -->
        <!-- 5. DISPATCHER — Rule Execution -->
        <!-- ============================================ -->
        <mxCell id="disp_title" value="&lt;b&gt;DISPATCHER&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="580" y="1100" width="130" height="20" as="geometry" />
        </mxCell>

        <mxCell id="dispatcher" value="&lt;b&gt;DispatcherActor&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Iterate ordered_rules sequentially&lt;br&gt;For each rule: lookup evaluator by RuleKind&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="1125" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_bt_disp" edge="1" source="build_tadpole" target="dispatcher" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_bt_disp_l" value="Tadpole with rules" style="edgeLabel;html=1;fontSize=9;fontColor=#555;" vertex="1" connectable="0" parent="e_bt_disp"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Rule kind decision -->
        <mxCell id="d_kind" value="Rule&lt;br&gt;Kind?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="605" y="1215" width="80" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_disp_kind" edge="1" source="dispatcher" target="d_kind" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Boolean Handler -->
        <mxCell id="bool_handler" value="&lt;b&gt;BooleanRuleHandler&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;1. Resolve snapshot from body.snapshots[object_type]&lt;br&gt;2. For each RuleCondition:&lt;br&gt;&amp;nbsp;&amp;nbsp; extract actual_value from snapshot&lt;br&gt;&amp;nbsp;&amp;nbsp; compare using operator (eq/neq/gt/lt/gte/lte/contains)&lt;br&gt;&amp;nbsp;&amp;nbsp; type coercion: NUMBER, BOOLEAN, STRING&lt;br&gt;3. AND logic: all conditions must pass&lt;br&gt;4. Fallback: evaluate CEL head expr if no conditions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="270" y="1195" width="290" height="110" as="geometry" />
        </mxCell>
        <mxCell id="e_kind_bool" edge="1" source="d_kind" target="bool_handler" style="rounded=1;strokeColor=#6c8ebf;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_kind_bool_l" value="Boolean" style="edgeLabel;html=1;fontSize=9;fontStyle=1;" vertex="1" connectable="0" parent="e_kind_bool"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Enrichment Stub -->
        <mxCell id="enrich_stub" value="&lt;b&gt;EnrichmentStubEvaluator&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Always returns INCONCLUSIVE&lt;br&gt;&quot;enrichment stub not implemented&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;dashPattern=8 4;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="1210" width="210" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_kind_enrich" edge="1" source="d_kind" target="enrich_stub" style="rounded=1;strokeColor=#d6b656;dashed=1;dashPattern=8 4;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_kind_enrich_l" value="EnrichmentStub" style="edgeLabel;html=1;fontSize=9;fontStyle=2;fontColor=#999;" vertex="1" connectable="0" parent="e_kind_enrich"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Full Enrichment (NOT STARTED) -->
        <mxCell id="enrich_full" value="&lt;b&gt;Enrichment Handler&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;External API calls&lt;br&gt;Data enrichment&lt;br&gt;&lt;b&gt;NOT STARTED&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;dashed=1;dashPattern=5 5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1210" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_stub_full" edge="1" source="enrich_stub" target="enrich_full" style="rounded=1;strokeColor=#b85450;dashed=1;dashPattern=5 5;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_stub_full_l" value="would replace" style="edgeLabel;html=1;fontSize=8;fontColor=#b85450;fontStyle=2;" vertex="1" connectable="0" parent="e_stub_full"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Condition evaluation result -->
        <mxCell id="rule_eval" value="&lt;b&gt;RuleEvaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;decision: PASS / FAIL / INCONCLUSIVE&lt;br&gt;checks[]: ConditionCheck per condition&lt;br&gt;duration_ms, reason_code, reason&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="520" y="1355" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_bool_eval" edge="1" source="bool_handler" target="rule_eval" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_enrich_eval" edge="1" source="enrich_stub" target="rule_eval" style="rounded=1;strokeColor=#999;dashed=1;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Short-circuit decision -->
        <mxCell id="d_sc" value="Fail_First&lt;br&gt;&amp;amp;&amp;amp; critical&lt;br&gt;&amp;amp;&amp;amp; FAIL?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="595" y="1450" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_eval_sc" edge="1" source="rule_eval" target="d_sc" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="sc_stop" value="&lt;font color=&quot;#cc0000&quot;&gt;&lt;b&gt;Short-Circuit&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Stop rule execution&lt;br&gt;Skip remaining rules&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="310" y="1455" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_sc_yes" edge="1" source="d_sc" target="sc_stop" style="rounded=1;strokeColor=#b85450;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sc_yes_l" value="Yes" style="edgeLabel;html=1;fontSize=9;fontColor=#b85450;fontStyle=1;" vertex="1" connectable="0" parent="e_sc_yes"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <mxCell id="d_more" value="More&lt;br&gt;rules?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="780" y="1460" width="80" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_sc_no" edge="1" source="d_sc" target="d_more" style="rounded=1;strokeColor=#333;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e_sc_no_l" value="No" style="edgeLabel;html=1;fontSize=9;fontStyle=1;" vertex="1" connectable="0" parent="e_sc_no"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- Loop back to dispatcher for next rule -->
        <mxCell id="e_more_yes" edge="1" source="d_more" target="d_kind" style="rounded=1;strokeColor=#666;curved=1;" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1000" y="1487" />
              <mxPoint x="1000" y="1245" />
              <mxPoint x="700" y="1245" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e_more_yes_l" value="Yes → next rule" style="edgeLabel;html=1;fontSize=9;fontColor=#666;" vertex="1" connectable="0" parent="e_more_yes"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>

        <!-- ============================================ -->
        <!-- 6. ORCHESTRATOR — Decision Aggregation -->
        <!-- ============================================ -->
        <mxCell id="orch_title" value="&lt;b&gt;ORCHESTRATOR&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#1a73e8;" vertex="1" parent="1">
          <mxGeometry x="565" y="1565" width="160" height="20" as="geometry" />
        </mxCell>

