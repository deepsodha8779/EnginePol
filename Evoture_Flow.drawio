        <mxCell id="l5" value="" style="shape=cylinder3;size=8;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="1310" y="55" width="14" height="18" as="geometry" /></mxCell>
        <mxCell id="l5t" value="Infrastructure" style="text;html=1;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="1328" y="56" width="70" height="16" as="geometry" /></mxCell>
        <mxCell id="l6" value="" style="rhombus;fillColor=#FFF9C4;strokeColor=#F9A825;" vertex="1" parent="1"><mxGeometry x="1410" y="55" width="16" height="16" as="geometry" /></mxCell>
        <mxCell id="l6t" value="Decision" style="text;html=1;fontSize=9;align=left;" vertex="1" parent="1"><mxGeometry x="1430" y="56" width="50" height="16" as="geometry" /></mxCell>

        <!-- ============================================ -->
