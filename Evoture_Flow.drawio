        <!-- ============================================ -->
        <mxCell id="src" value="&lt;b&gt;OutSystems&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Domain Change Event&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="620" y="90" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- 2. INGRESS — two paths -->
        <!-- ============================================ -->
        <mxCell id="http" value="&lt;b&gt;HTTP Intake API&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;POST /intake (intake_api.rs)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="185" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="rmq_broker" value="&lt;b&gt;RabbitMQ Broker&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;AMQP (lapin)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="870" y="175" width="130" height="55" as="geometry" />
        </mxCell>
        <mxCell id="rmq_consumer" value="&lt;b&gt;RabbitMQ Consumer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Queue: events_intake&lt;br&gt;auto-ack / nack&lt;br&gt;10s reconnect (rabbitmq_consumer.rs)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="850" y="275" width="180" height="60" as="geometry" />
        </mxCell>

        <!-- source edges -->
        <mxCell id="e1" edge="1" source="src" target="http" style="rounded=1;strokeColor=#6c8ebf;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1l" value="HTTP" style="edgeLabel;html=1;fontSize=9;" vertex="1" connectable="0" parent="e1"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
        <mxCell id="e2" edge="1" source="src" target="rmq_broker" style="rounded=1;strokeColor=#82b366;" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2l" value="Publish" style="edgeLabel;html=1;fontSize=9;" vertex="1" connectable="0" parent="e2"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry></mxCell>
